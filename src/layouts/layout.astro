---
// src/layouts/layout.astro — Version standard avec ClientRouter
import '../styles/global.css';
import Header from './header.astro';
import Footer from './footer.astro';
import { ClientRouter } from 'astro:transitions';
import HreflangLinks from '../components/HreflangLinks.astro';

export interface Props {
  title: string;
  description: string;
  lang: string;
  image?: string;
}

const { title, description, lang: requestedLang = 'fr', image } = Astro.props;

const langAttributes = {
  fr: { htmlLang: 'fr', ogLocale: 'fr_FR' },
  en: { htmlLang: 'en', ogLocale: 'en_US' },
  de: { htmlLang: 'de', ogLocale: 'de_DE' },
};

const lang = requestedLang in langAttributes ? requestedLang : 'fr';
const { htmlLang, ogLocale } = langAttributes[lang as keyof typeof langAttributes];

const canonicalURL = Astro.url.href;
const siteUrl = Astro.site ?? new URL('https://jkw.ovh/');
const ogImage = new URL(image ?? '/og-image.jpg', siteUrl).href;

const jobTitles = {
  fr: 'Développeur Web Full Stack',
  en: 'Full Stack Web Developer',
  de: 'Full-Stack-Webentwickler',
};

const serviceNames = {
  fr: ['Création de sites web', 'Applications web sur mesure', 'Boutiques en ligne', 'Audit et optimisation web'],
  en: ['Website creation', 'Custom web applications', 'Online stores', 'Web audit and optimization'],
  de: ['Website-Erstellung', 'Maßgeschneiderte Webanwendungen', 'Online-Shops', 'Web-Audit und Optimierung'],
};

const personUrl = new URL(`/${lang}/`, siteUrl).href;

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}#person`,
      "name": "Josselin HANEL",
      "jobTitle": jobTitles[lang as keyof typeof jobTitles],
      "url": personUrl,
      "sameAs": [
        "https://github.com/KewneWhimsy",
        "https://www.instagram.com/whimsyjoss/"
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}#business`,
      "name": "Josselin HANEL - Développeur Web",
      "url": personUrl,
      "telephone": "+33781339768",
      "email": "josshanel@gmail.com",
      "founder": { "@id": `${siteUrl}#person` },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Rennes",
        "addressRegion": "Bretagne",
        "addressCountry": "FR"
      },
      "areaServed": [
        { "@type": "City", "name": "Rennes" },
        { "@type": "City", "name": "Quimper" },
        { "@type": "City", "name": "Paris" },
        { "@type": "City", "name": "Berlin" },
        { "@type": "Country", "name": "France" }
      ],
      "priceRange": "55€/h",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": lang === 'fr' ? "Services web" : lang === 'en' ? "Web services" : "Web-Dienstleistungen",
        "itemListElement": serviceNames[lang as keyof typeof serviceNames].map(name => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": name
          }
        }))
      }
    }
  ]
});
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Josselin HANEL" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1440" />
    <meta property="og:image:height" content="1440" />
    <meta property="og:site_name" content="Josselin HANEL" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/jpointr.png" type="image/png" />
    <HreflangLinks />
    <title>{title}</title>
    <script type="application/ld+json" set:html={structuredData} />
    <slot name="head" />
    <ClientRouter />

    <script>
      function updateNavigationLinks() {
        const path = window.location.pathname;
        const langMatch = path.match(/^\/([a-z]{2})(\/|$)/);
        const currentLang = langMatch ? langMatch[1] : 'fr';
        const logoLink = document.querySelector('a.titleName');
        if (logoLink) logoLink.setAttribute('href', `/${currentLang}/`);
      }
      document.addEventListener('astro:page-load', updateNavigationLinks);
      document.addEventListener('DOMContentLoaded', updateNavigationLinks);
    </script>

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              if (entry.target.classList.contains('fade-in')) {
                entry.target.classList.remove('opacity-0', 'translate-y-6');
              }
              const scaleUpBlocks = entry.target.querySelectorAll('.scale-up');
              if (scaleUpBlocks.length > 0) {
                scaleUpBlocks.forEach((block, index) => {
                  setTimeout(() => block.classList.add('visible'), index * 200);
                });
              }
              observer.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -5% 0px', threshold: 0.1 });

        document.querySelectorAll('.fade-in, section.py-4.mb-12').forEach(section => {
          observer.observe(section);
        });
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="mx-2 md:mx-4">
      <Header />
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="mx-4">
      <Footer />
    </footer>
  </body>
</html>
