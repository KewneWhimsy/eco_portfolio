---
import { getLangFromPath, t } from '../i18n';
import { footer } from '../i18n/common';
const { pathname } = Astro.url;
const currentLang = getLangFromPath(pathname);
const text = t(footer, currentLang);
const currentYear = new Date().getFullYear();
---
<div class="border-t border-accent/20 mt-8 py-6">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <div class="mb-4 md:mb-0">
        <p class="text-text-muted text-sm">&copy; {currentYear} {text.copyright}</p>
        <p class="text-text-muted text-sm mt-1">{text.ecoDesignDesc}</p>
        <div class="mt-3 text-xs flex gap-4">
          <a href={`/${currentLang}/privacy/`} class="text-text-muted hover:text-accent transition-colors">{text.privacyPolicy}</a>
          <a href={`/${currentLang}/legal/`} class="text-text-muted hover:text-accent transition-colors">{text.legalNotice}</a>
        </div>
      </div>
      <div class="text-right">
        <h3 class="text-xs font-bold uppercase tracking-widest text-accent mb-2">{text.availability}</h3>
        <p class="text-text-muted text-sm">{text.locations}</p>
      </div>
    </div>
  </div>
</div>
