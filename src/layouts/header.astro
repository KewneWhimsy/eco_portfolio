---
// src/layouts/header.astro — tous les liens passent en éco quand on est en éco
import EcoModeToggle from '../components/eco_mode_toggle.astro';
import LanguageSwitcher from '../components/language_switcher.astro';
import { getLangFromPath, t } from '../i18n';
import { nav } from '../i18n/common';

const { pathname } = Astro.url;
const currentLang = getLangFromPath(pathname);
const isEcoMode = pathname.includes('/eco');
const labels = t(nav, currentLang);

const ecoSuffix = isEcoMode ? 'eco/' : '';
const homeHref = isEcoMode ? `/${currentLang}/eco/` : `/${currentLang}/`;
---

<div class="py-6 md:mb-8">
  <div class="flex flex-col md:flex-row justify-between items-center">
    <div class="mb-3 md:mb-0 mr-2 whitespace-nowrap" data-astro-transition-persist="header-logo">
      <a href={homeHref} class="titleName text-2xl font-bold no-underline hover:text-accent">
        Josselin HANEL<span class="titlePoint text-accent">.</span>
      </a>
    </div>

    <input type="checkbox" id="menu-toggle" class="hidden peer" />
    <label for="menu-toggle" class="burger-container md:hidden cursor-pointer rounded hover:bg-secondary mb-3" aria-label="Menu">
      <div class="burger-bar"></div>
    </label>

    <div class="grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] md:grid-rows-[1fr] transition-[grid-template-rows] duration-300 w-full md:w-auto">
    <div class="overflow-hidden">
    <div class="flex flex-col md:flex-row gap-4 items-center w-full md:w-auto md:my-0">
      <nav class="w-full md:w-auto">
        <ul class="flex flex-col md:flex-row items-center gap-3 md:gap-4">
          <li>
            <a href={`/${currentLang}/projects/${ecoSuffix}`}
              class={`nav-link ${pathname.includes('/projects') ? 'nav-link-active' : ''}`}>
              {labels.projects}
            </a>
          </li>
          <li>
            <a href={`/${currentLang}/about/${ecoSuffix}`}
              class={`nav-link whitespace-nowrap ${pathname.includes('/about') ? 'nav-link-active' : ''}`}>
              {labels.about}
            </a>
          </li>
          <li>
            <a href={`/${currentLang}/services/${ecoSuffix}`}
              class={`nav-link ${pathname.includes('/services') ? 'nav-link-active' : ''}`}>
              {labels.services}
            </a>
          </li>
          <li>
            <a href={`/${currentLang}/blog/${ecoSuffix}`}
              class={`nav-link ${pathname.includes('/blog') ? 'nav-link-active' : ''}`}>
              {labels.blog}
            </a>
          </li>
          <li>
            <a href={`/${currentLang}/network/${ecoSuffix}`}
              class={`nav-link ${pathname.includes('/network') ? 'nav-link-active' : ''}`}>
              {labels.network}
            </a>
          </li>
          <li>
            <a href={`/${currentLang}/contact/${ecoSuffix}`}
              class={`nav-link ${pathname.includes('/contact') ? 'nav-link-active' : ''}`}>
              {labels.contact}
            </a>
          </li>
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-4">
        <LanguageSwitcher />
        <EcoModeToggle />
      </div>
    </div>
    </div>
    </div>

    <div class="flex items-center gap-4 md:hidden peer-checked:mt-5">
      <LanguageSwitcher />
      <EcoModeToggle />
    </div>
  </div>
</div>

<style>
  .burger-container {
    position: relative;
    width: 34px;
    height: 34px;
  }
  .burger-bar,
  .burger-bar::before,
  .burger-bar::after {
    position: absolute;
    height: 2px;
    width: 20px;
    background: currentColor;
    border-radius: 10px;
    transition: 300ms cubic-bezier(0.54, -0.65, 0.45, 1.65);
  }
  .burger-bar {
    top: 16px; /* (34 - 2) / 2 */
    left: 7px;  /* (34 - 20) / 2 */
  }
  .burger-bar::before,
  .burger-bar::after {
    content: "";
    left: 0;
  }
  .burger-bar::before {
    top: -7px;
  }
  .burger-bar::after {
    top: 7px;
  }
  #menu-toggle:checked + .burger-container .burger-bar {
    width: 0;
  }
  #menu-toggle:checked + .burger-container .burger-bar::before {
    top: 0;
    transform: rotate(45deg);
  }
  #menu-toggle:checked + .burger-container .burger-bar::after {
    top: 0;
    transform: rotate(-45deg);
  }
</style>
