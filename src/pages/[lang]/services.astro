---
// src/pages/[lang]/services.astro — v2 avec i18n
import Layout from '../../layouts/layout.astro';
import { getLangPaths, t } from '../../i18n';
import { services } from '../../i18n/services';
import Icon from '../../components/Icon.astro';
import FormWeb3Standard from '../../components/FormWeb3Standard.astro';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(services, lang);
---

<Layout title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-8">
    <!-- En-tête -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">{text.pageTitle}</h1>
      <p class="text-xl text-text-muted max-w-3xl mx-auto">{text.intro}</p>
    </div>

    <!-- Approche -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8 text-center text-accent">{text.approachTitle}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {text.approaches.map(a => (
          <div class="skill-card-home p-5">
            <div class="skill-card-home-bar" aria-hidden="true"></div>
            <div class="flex justify-center mb-3 mt-3 text-light">
              <Icon name={a.icon} size={36} />
            </div>
            <h3 class="font-semibold mb-2 text-center">{a.title}</h3>
            <p class="text-sm text-text-muted text-center">{a.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Services -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8 text-center text-accent">{text.servicesTitle}</h2>
      <div class="grid lg:grid-cols-3 gap-8">
        {text.services.map(s => (
          <div class="skill-card-home p-6">
            <div class="skill-card-home-bar" aria-hidden="true"></div>
            <h3 class="text-xl font-bold mb-2 mt-2">{s.title}</h3>
            <div class="text-accent font-bold text-lg mb-3">{s.price}</div>
            <p class="text-text-muted mb-4">{s.description}</p>
            <ul class="space-y-2 mb-4">
              {s.features.map((f, i) => <li class="flex items-center gap-2"><Icon name="checkmark" size={16} class={`text-light shrink-0 ${i === s.features.length - 1 ? 'font-semibold' : ''}`} /><span class={i === s.features.length - 1 ? 'text-light font-semibold' : ''}>{f}</span></li>)}
            </ul>
            <p class="text-accent italic">{s.ideal}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Processus -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8 text-center text-accent">Workflow</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {text.processSteps.map(s => (
          <div class="text-center">
            <div class="bg-accent text-primary w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">{s.step}</div>
            <h3 class="font-semibold mb-2">{s.title}</h3>
            <p class="text-text-muted">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA + Formulaire -->
    <section class="border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none p-8 mb-16">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold mb-4 text-accent">{text.ctaTitle}</h2>
        <p class="text-text-muted">{text.ctaDesc}</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <FormWeb3Standard
          formId="services-form"
          fromName="Portfolio Services"
          subjectHidden="Nouvelle demande de devis - Services"
          submitLabel={text.submitButton}
          submittingLabel={text.formSubmitting}
          successMsg={text.formSuccess}
          errorMsg={text.formError}
        >
          <h3 class="text-xl font-semibold mb-4">{text.formTitle}</h3>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block mb-1 font-medium">{text.nameLabel} *</label>
              <input type="text" id="name" name="name" class="w-full p-3 form-field" required />
            </div>
            <div>
              <label for="email" class="block mb-1 font-medium">{text.emailLabel} *</label>
              <input type="email" id="email" name="email" class="w-full p-3 form-field" required />
            </div>
          </div>
          <div>
            <label for="company" class="block mb-1 font-medium">{text.companyLabel}</label>
            <input type="text" id="company" name="company" class="w-full p-3 form-field" />
          </div>
          <div>
            <label for="project_type" class="block mb-1 font-medium">{text.projectTypeLabel} *</label>
            <select id="project_type" name="project_type" class="w-full p-3 form-field" required>
              {Object.entries(text.projectTypes).map(([val, label]) => <option value={val}>{label}</option>)}
            </select>
          </div>
          <div>
            <label for="message" class="block mb-1 font-medium">{text.messageLabel} *</label>
            <textarea id="message" name="message" rows="5" class="w-full p-3 form-field" placeholder={text.messagePlaceholder} required />
          </div>
        </FormWeb3Standard>
      </div>
    </section>

    <!-- Détails des offres -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-6 text-center text-accent">{text.detailsTitle}</h2>
      <p class="text-center text-text-muted mb-8 max-w-2xl mx-auto">{text.detailsIntro}</p>

      <div class="space-y-4 max-w-4xl mx-auto">
        <!-- Vitrine -->
        <details class="border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none">
          <summary class="p-6 cursor-pointer font-bold text-xl hover:text-accent transition-colors flex items-center gap-3 text-pretty">
            <Icon name="monitor" size={20} class="text-light shrink-0" />{text.vitrineDetails.title}
          </summary>
          <div class="px-6 pb-6 space-y-6">
            {text.vitrineDetails.options.map(o => (
              <div class="border-l-4 border-accent pl-4 py-2">
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold text-lg">{o.name}</h4>
                  <span class="text-accent font-bold whitespace-nowrap ml-4">{o.price}</span>
                </div>
                <p class="text-accent mb-3">{o.maintenance}</p>
                <p class="mb-3">{o.desc}</p>
                <ul class="space-y-2 mb-3">
                  {o.features.map(f => <li class="flex items-center gap-2"><Icon name="checkmark" size={15} class="text-light shrink-0" /><span>{f}</span></li>)}
                </ul>
                {o.modifications && <p class="text-text-muted mb-2">{o.modifications}</p>}
                {o.tech && <p class="text-text-muted mb-2 italic">{o.tech}</p>}
                <p class="text-accent italic">{o.ideal}</p>
              </div>
            ))}
            <p class="text-center bg-primary/30 p-3 rounded text-sm border border-accent/20">
              {text.vitrineDetails.comparison.split(' | ').map((part, i, arr) => (
                <span>
                  <span class="text-light font-semibold">{part.split(' = ')[0]}</span>
                  <span class="text-text-muted"> = {part.split(' = ')[1]}</span>
                  {i < arr.length - 1 && <span class="text-accent mx-2">|</span>}
                </span>
              ))}
            </p>
          </div>
        </details>

        <!-- E-commerce -->
        <details class="border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none">
          <summary class="p-6 cursor-pointer font-bold text-xl hover:text-accent transition-colors flex items-center gap-3 text-pretty">
            <Icon name="cart" size={20} class="text-light shrink-0" />{text.ecommerceDetails.title}
          </summary>
          <div class="px-6 pb-6 space-y-6">
            {text.ecommerceDetails.options.map(o => (
              <div class="border-l-4 border-accent pl-4 py-2">
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold text-lg">{o.name}</h4>
                  <span class="text-accent font-bold whitespace-nowrap ml-4">{o.price}</span>
                </div>
                <p class="text-accent mb-3">{o.maintenance}</p>
                <p class="mb-3">{o.desc}</p>
                <ul class="space-y-2 mb-3">
                  {o.features.map(f => <li class="flex items-center gap-2"><Icon name="checkmark" size={15} class="text-light shrink-0" /><span>{f}</span></li>)}
                </ul>
                {o.tech && <p class="text-text-muted mb-2 italic">{o.tech}</p>}
                <p class="text-accent italic">{o.ideal}</p>
              </div>
            ))}
            <p class="text-center bg-primary/30 p-3 rounded text-sm border border-accent/20">
              {text.ecommerceDetails.comparison.split(' | ').map((part, i, arr) => (
                <span>
                  <span class="text-light font-semibold">{part.split(' = ')[0]}</span>
                  <span class="text-text-muted"> = {part.split(' = ')[1]}</span>
                  {i < arr.length - 1 && <span class="text-accent mx-2">|</span>}
                </span>
              ))}
            </p>
          </div>
        </details>

        <!-- Sur-mesure -->
        <details class="border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none">
          <summary class="p-6 cursor-pointer font-bold text-xl hover:text-accent transition-colors flex items-center gap-3 text-pretty">
            <Icon name="gear" size={20} class="text-light shrink-0" />{text.customDetails.title}
          </summary>
          <div class="px-6 pb-6">
            <p class="text-accent font-bold text-lg mb-3">{text.customDetails.rate}</p>
            <p class="mb-4">{text.customDetails.desc}</p>
            <h4 class="font-semibold mb-3">{text.customDetails.examplesLabel}</h4>
            <ul class="grid md:grid-cols-2 gap-2 mb-6">
              {text.customDetails.examples.map(e => <li class="flex items-start"><span class="text-accent mr-2">•</span><span>{e}</span></li>)}
            </ul>
            <div class="bg-primary bg-opacity-30 p-4 rounded text-center">
              <h4 class="font-semibold mb-2 text-accent flex items-center gap-2"><Icon name="rocket" size={18} class="text-light" />{text.customDetails.largeProjects.title}</h4>
              <p class="text-balance mb-2">{text.customDetails.largeProjects.desc}</p>
              <p class="text-balance italic text-text-muted">{text.customDetails.largeProjects.why}</p>
            </div>
          </div>
        </details>
      </div>
    </section>

    <!-- Infos complémentaires -->
    <div class="grid lg:grid-cols-2 gap-8 mb-12">
    <div class="skill-card-home p-6">
    <div class="skill-card-home-bar" aria-hidden="true"></div>
        <h3 class="text-xl font-bold mb-4 text-accent mt-2">{text.includesTitle}</h3>
        <ul class="space-y-2">
        {text.includes.map(i => <li class="flex items-center gap-2"><Icon name="checkmark" size={15} class="text-light shrink-0" /><span>{i}</span></li>)}
        </ul>
        <p class="pt-4 text-light text-sm italic">{text.contactDirect.note}</p>
      </div>
      <div class="skill-card-home p-6">
        <div class="skill-card-home-bar" aria-hidden="true"></div>
        <h3 class="text-xl font-bold mb-4 text-accent mt-2">{text.whyTitle}</h3>
        <ul class="space-y-2">
          {text.whyReasons.map(r => <li class="flex items-center gap-2"><Icon name="leaf" size={15} class="text-light shrink-0" /><span>{r}</span></li>)}
        </ul>
      </div>
    </div>

    <!-- Contact direct -->
    <div class="text-center p-6 border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none">
      <h3 class="text-lg font-semibold mb-2">{text.contactDirect.title}</h3>
      <p class="text-text-muted mb-4">{text.contactDirect.text}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-3">
        <p class="text-light flex items-center gap-2"><Icon name="phone" size={16} class="shrink-0" /><span class="select-all">+33 7 81 33 97 68</span></p>
        <p class="text-light flex items-center gap-2"><Icon name="mail" size={16} class="shrink-0" /><span class="select-all">josshanel@gmail.com</span></p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .skill-card-home {
    position: relative;
    background: color-mix(in srgb, var(--color-secondary) 25%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    overflow: hidden;
  }
  .skill-card-home-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-light), transparent);
    opacity: 0.7;
  }
</style>
