---
// src/pages/[lang]/contact.astro — v2 avec i18n
import Layout from '../../layouts/layout.astro';
import { Picture } from 'astro:assets';
import monImage from '../../assets/j.jpg';
import { getLangPaths, t } from '../../i18n';
import { contact } from '../../i18n/contact';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(contact, lang);

const contactInfo = {
  email: 'josshanel@gmail.com',
  phone: '+33 7 81 33 97 68',
};
---

<Layout title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 border-b border-accent pb-2">{text.pageTitle}</h1>

    <div class="flex flex-col lg:flex-row gap-8 mb-12">
      <!-- Infos de contact -->
      <div class="lg:w-1/2">
        <p class="mb-8 text-lg">{text.introText}</p>

        <div class="skill-card-home p-6 mb-6">
          <div class="skill-card-home-bar" aria-hidden="true"></div>
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-accent mb-2">{text.emailTitle}</h2>
            <p class="flex items-center text-link">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="select-all">{contactInfo.email}</span>
            </p>
          </div>
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-accent mb-2">{text.phoneTitle}</h2>
            <p class="flex items-center text-link">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="select-all">{contactInfo.phone}</span>
            </p>
          </div>
          <div class="mb-2">
            <h2 class="text-xl font-semibold text-accent mb-2">{text.locationTitle}</h2>
            <p set:html={text.locationText} />
          </div>
        </div>

        <div class="skill-card-home p-6">
          <div class="skill-card-home-bar" aria-hidden="true"></div>
          <h2 class="text-xl font-semibold text-accent mb-2 mt-2">{text.preferenceTitle}</h2>
          <p>{text.preferenceText}</p>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="lg:w-1/2">
        <div class="skill-card-home p-6">
          <div class="skill-card-home-bar" aria-hidden="true"></div>
          <h2 class="text-xl font-semibold text-accent mb-4 mt-2">{text.formTitle}</h2>
          <form id="contact-form" class="space-y-4">
            <input type="hidden" name="access_key" value="2dcc3f1b-036f-48a7-987a-cdada0d05ae5" />
            <input type="hidden" name="from_name" value="Portfolio Contact" />
            <div>
              <label for="name" class="block mb-1 font-medium">{text.formName} *</label>
              <input type="text" id="name" name="name" class="w-full p-2 form-field" required />
            </div>
            <div>
              <label for="email" class="block mb-1 font-medium">{text.formEmail} *</label>
              <input type="email" id="email" name="email" class="w-full p-2 form-field" required />
            </div>
            <div>
              <label for="phone" class="block mb-1 font-medium">{text.formPhone}</label>
              <input type="tel" id="phone" name="phone" class="w-full p-2 form-field" />
            </div>
            <div>
              <label for="subject" class="block mb-1 font-medium">{text.formSubject} *</label>
              <select id="subject" name="subject" class="w-full p-2 form-field" required>
                {Object.entries(text.subjectOptions).map(([val, label]) => <option value={val}>{label}</option>)}
              </select>
            </div>
            <div>
              <label for="message" class="block mb-1 font-medium">{text.formMessage} *</label>
              <textarea id="message" name="message" rows="5" class="w-full p-2 form-field" placeholder={text.formMessagePlaceholder} required />
            </div>
            <div class="hidden"><input type="text" name="botcheck" /></div>
            <div class="flex justify-end">
              <button type="submit" id="submit-button" class="cta-button">{text.formSubmit}</button>
              <span id="form-spinner" style="display: none;" class="inline-flex items-center ml-3">
                <svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                </svg>
                {text.formSubmitting}
              </span>
            </div>
            <div id="form-status" class="mt-4"></div>
          </form>
          <p class="mt-6 text-sm text-text-muted">{text.afterFormText}</p>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ translations: text }}>
    document.addEventListener('astro:page-load', setupContactForm);
    function setupContactForm() {
      const form = document.getElementById('contact-form');
      if (form.dataset.initialized) return;
      form.dataset.initialized = 'true';
      const formStatus = document.getElementById('form-status');
      const submitButton = document.getElementById('submit-button');
      const formSpinner = document.getElementById('form-spinner');
      if (!form || !formStatus || !submitButton || !formSpinner) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitButton.disabled = true;
        formSpinner.style.display = 'inline-flex';
        formStatus.innerHTML = '';
        try {
          const formData = new FormData(form);
          if (formData.get('botcheck')) throw new Error('Bot detected!');
          const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
          const data = await response.json();
          if (data.success) {
            formStatus.innerHTML = `<p class="bg-accent text-primary text-center font-medium px-4 py-2 rounded">✓ ${translations.formSuccess}</p>`;
            form.reset();
          } else { throw new Error(data.message || 'Something went wrong!'); }
        } catch (error) {
          formStatus.innerHTML = `<p class="bg-red-600 text-white text-center font-medium px-4 py-2 rounded">✕ ${translations.formError}</p>`;
        } finally {
          submitButton.disabled = false;
          formSpinner.style.display = 'none';
        }
      });
    }
  </script>

<style>
  .skill-card-home {
    position: relative;
    background: color-mix(in srgb, var(--color-secondary) 25%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    overflow: hidden;
  }
  .skill-card-home-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-light), transparent);
    opacity: 0.7;
  }
</style>
</Layout>
