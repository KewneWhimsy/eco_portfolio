---
// src/pages/[lang]/legal.astro
import Layout from '../../layouts/layout.astro';
import LegalContent from '../../components/LegalContent.astro';
import { getLangPaths, t } from '../../i18n';
import { legal } from '../../i18n/legal';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(legal, lang);
---

<Layout title={text.title} description={text.description} lang={lang}>
  <LegalContent lang={lang} backHref={`/${lang}/`} />
</Layout>
