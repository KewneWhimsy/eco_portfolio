---
// src/pages/[lang]/index.astro — v2 avec i18n externalisé
import Layout from '../../layouts/layout.astro';
import { Picture } from 'astro:assets';
import CtaDispo from '../../components/cta_dispo.astro';
import ProfilePicture from '../../components/ProfilePicture.astro';
import { getCollection } from 'astro:content';
import { loadHeroImage } from '../../utils/imageLoader';
import { getLangPaths, t } from '../../i18n';
import { home } from '../../i18n/home';
import Icon from '../../components/Icon.astro';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(home, lang);

// Projets récents (2 derniers)
const allProjects = await getCollection('projects');
const recentProjects = allProjects
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 2);

// Articles de blog récents (3 derniers)
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Helper date
function formatDate(date: Date): string {
  return date.toLocaleDateString(
    lang === 'fr' ? 'fr-FR' : lang === 'de' ? 'de-DE' : 'en-US',
    { year: 'numeric', month: 'short', day: 'numeric' }
  );
}
---

<Layout title={text.title} description={text.description} lang={lang}>
  <div class="container md:mt-3 mt-0 mx-auto px-4 md:py-8 py-0">

    <!-- Hero -->
    <section class="py-8 md:py-12">
      <div class="flex flex-col md:flex-row gap-8">
        <div class="md:w-2/3">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">
            <div class="flex flex-wrap items-baseline gap-2">
              <div class="typewriter-part1">
                <span class="typewriter-text-base">{text.heroTypePart1}</span>
              </div>
              <div class="typewriter-part2">
                <span class="typewriter-text-highlight text-light">{text.heroTypePart2}</span>
              </div>
            </div>
          </h1>
          <p class="text-lg mb-6">{text.heroText}</p>
          <div class="flex flex-wrap gap-4">
            <a href={`/${lang}/contact/`} class="cta-button">{text.contactButton}</a>
            <a href={`/${lang}/projects/`} class="btn-secondary">{text.projectsButton}</a>
          </div>
        </div>
        <div class="md:w-1/3">
          <ProfilePicture alt={`Josselin HANEL - ${text.heroTypePart1} ${text.heroTypePart2}`} class="max-w-4/5" />
        </div>
      </div>
    </section>

    <!-- Valeurs -->
    <section class="py-4 mb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {text.values.map((value, index) => (
            <div class="skill-card-home p-6 scale-up" data-index={index}>
              <div class="skill-card-home-bar" aria-hidden="true"></div>
              <div class="flex justify-between items-start mb-3 mt-2">
                <h2 class="text-base font-bold uppercase tracking-wide text-accent">{value.title}</h2>
                <Icon name={value.icon} size={28} class="text-light shrink-0 -mt-2 -mr-2" />
              </div>
              <p class="text-text-muted">{value.description}</p>
            </div>
          ))}
      </div>
    </section>

    <!-- Services -->
    <section class="py-2 sm:py-8 mb-12 fade-in opacity-0 translate-y-6 transition-all duration-500">
      <h2 class="text-2xl font-bold mb-6 border-b border-accent pb-2">{text.servicesTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {text.services.map(service => (
          <div class="skill-card-home p-5">
            <div class="skill-card-home-bar" aria-hidden="true"></div>
            <div class="flex justify-between items-start mb-3 mt-2">
              <h3 class="text-base font-bold uppercase tracking-wide text-accent">{service.title}</h3>
              <Icon name={service.icon} size={28} class="text-light shrink-0" />
            </div>
            <p>{service.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Blog récent -->
    {recentPosts.length > 0 && (
      <section class="py-2 sm:py-8 mb-12 fade-in opacity-0 translate-y-6 transition-all duration-500">
        <h2 class="text-2xl font-bold mb-6 border-b border-accent pb-2">{text.blogTitle}</h2>
        <div class="space-y-4">
          {recentPosts.map(post => (
            <a
              href={`/${lang}/blog/${post.data.slug}/`}
              class="article-link block py-4 border-b border-accent/10"
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
                <h3 class="text-lg font-semibold text-accent">{post.data.title[lang]}</h3>
                <time class="text-xs text-text-muted shrink-0" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              <p class="text-text-muted">{post.data.description[lang]}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-6">
          <a href={`/${lang}/blog/`} class="btn-secondary">{text.viewAllBlogButton}</a>
        </div>
      </section>
    )}

    <!-- Projets récents -->
    <section class="py-2 sm:py-8 fade-in opacity-0 translate-y-6 transition-all duration-500">
      <h2 class="text-2xl font-bold mb-6 border-b border-accent pb-2">{text.projectsTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {recentProjects.map(async (project) => {
          const heroImage = await loadHeroImage(project.data.slug);
          return (
            <div class="project-card w-full">
              <div class="flex flex-col flex-1">
                <a href={`/${lang}/${project.data.slug}/`} class="block bg-primary bg-opacity-30 aspect-video w-full relative overflow-hidden">
                  <Picture
                    src={heroImage}
                    widths={[400, 740, 1080]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    formats={['avif', 'webp', 'jpg']}
                    alt={project.data.title[lang]}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                  />
                </a>
                <div class="p-4 flex flex-col h-full">
                  <div class="flex-1">
                    <h3 class="text-xl font-bold mb-2">{project.data.title[lang]}</h3>
                    <p class="mb-4" set:html={project.data.description[lang]} />
                    <div class="mb-4">
                      <div class="flex flex-wrap gap-1.5">
                        {project.data.tech.map(tech => (
                          <span class="px-2 py-0.5 border border-accent text-light rounded-full text-xs">{tech}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                  <div class="mt-auto">
                    <a href={`/${lang}/${project.data.slug}/`} class="btn-secondary flex-1 text-center block">
                      {text.projectButton}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      <div class="text-center mt-8">
        <a href={`/${lang}/projects/`} class="btn-secondary">{text.viewAllProjectsButton}</a>
      </div>
    </section>

    <!-- CTA -->
    <section>
      <CtaDispo transition-persist="cta-dispo" />
    </section>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (entry.target.classList.contains('fade-in')) {
              entry.target.classList.remove('opacity-0', 'translate-y-6');
            }
            const scaleUpBlocks = entry.target.querySelectorAll('.scale-up');
            if (scaleUpBlocks.length > 0) {
              scaleUpBlocks.forEach((block, index) => {
                setTimeout(() => block.classList.add('visible'), index * 200);
              });
            }
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -5% 0px', threshold: 0.1 });

      document.querySelectorAll('.fade-in, section.py-4.mb-12').forEach(section => {
        observer.observe(section);
      });
    });
  </script>

  <style>
    .skill-card-home {
      position: relative;
      background: color-mix(in srgb, var(--color-secondary) 25%, transparent);
      border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
      border-radius: 1rem;
      border-top-right-radius: 0;
      border-bottom-left-radius: 0;
      overflow: hidden;
    }
    .skill-card-home-bar {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--color-accent), var(--color-light), transparent);
      opacity: 0.7;
    }
    .article-link {
      transition: color 0.2s;
    }
    .article-link:hover h3 {
      color: var(--color-light);
    }
  </style>
</Layout>
