---
// src/pages/[lang]/privacy/eco.astro — mêmes traductions, layout éco
import LayoutEco from '../../../layouts/layout-eco.astro';
import { getLangPaths, t } from '../../../i18n';
import { privacy } from '../../../i18n/privacy';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(privacy, lang);
---

<LayoutEco title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-2xl font-bold mb-4 border-b border-accent pb-2">{text.pageTitle}</h1>
    <p class="text-text-muted mb-6">{text.lastUpdated}</p>
    <p class="mb-8">{text.intro}</p>

    <section class="mb-6">
      <h2 class="text-xl font-semibold mb-3 text-accent">{text.dataCollection.title}</h2>
      <p class="mb-3">{text.dataCollection.content}</p>
      {text.dataCollection.items.map(item => (
        <div class="mb-3 pl-3 border-l-2 border-accent">
          <h3 class="font-medium">{item.title}</h3>
          <p class="text-sm">{item.description}</p>
        </div>
      ))}
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold mb-2">{text.noTracking.title}</h2>
      <p>{text.noTracking.content}</p>
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold mb-2">{text.rights.title}</h2>
      <p>{text.rights.content}</p>
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold mb-2">{text.security.title}</h2>
      <p>{text.security.content}</p>
    </section>

    <div class="text-center mt-10">
      <a href={`/${lang}/eco/`} class="btn-secondary inline-block">{text.backLink}</a>
    </div>
  </div>
</LayoutEco>
