---
// src/pages/[lang]/privacy.astro — v2 avec i18n
import Layout from '../../layouts/layout.astro';
import { getLangPaths, t } from '../../i18n';
import { privacy } from '../../i18n/privacy';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(privacy, lang);
---

<Layout title={text.title} description={text.description} lang={lang}>
  <div transition:name="privacy" class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4 border-b border-accent pb-2">{text.pageTitle}</h1>
    <p class="text-text-muted mb-6">{text.lastUpdated}</p>
    <p class="text-lg mb-8">{text.intro}</p>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4 text-accent">{text.dataCollection.title}</h2>
      <p class="mb-4">{text.dataCollection.content}</p>
      <div class="space-y-4 pl-4">
        {text.dataCollection.items.map(item => (
          <div>
            <h3 class="font-medium text-accent">{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-8 bg-secondary bg-opacity-30 p-4 rounded-lg">
      <h2 class="text-xl font-semibold mb-2">{text.noTracking.title}</h2>
      <p>{text.noTracking.content}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-2">{text.processingData.title}</h2>
      <p set:html={text.processingData.content} />
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-2">{text.rights.title}</h2>
      <p>{text.rights.content}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-2">{text.security.title}</h2>
      <p>{text.security.content}</p>
    </section>

    <section class="mb-8 border-t border-secondary pt-4">
      <h2 class="text-xl font-semibold mb-2">{text.contactSection.title}</h2>
      <span>{text.contactSection.content}</span>
      <a href={`/${lang}/contact/`} class="text-link">{text.contactSection.contactMe}</a>.
    </section>

    <div class="text-center mt-10">
      <a href={`/${lang}/`} class="btn-secondary inline-block">{text.backLink}</a>
    </div>
  </div>
</Layout>
