---
// src/pages/[lang]/services/eco.astro — mêmes traductions, template léger
import LayoutEco from '../../../layouts/layout-eco.astro';
import EcoModeInfo from '../../../components/eco_mode_info.astro';
import Icon from '../../../components/Icon.astro';
import FormWeb3Eco from '../../../components/FormWeb3Eco.astro';
import { getLangPaths, t } from '../../../i18n';
import { services } from '../../../i18n/services';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(services, lang);
---

<LayoutEco title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-6 max-w-3xl">
    <EcoModeInfo lang={lang} />

    <h1 class="text-2xl font-bold mb-4 border-b border-accent pb-2">{text.pageTitle}</h1>
    <p class="mb-6">{text.intro}</p>

    <!-- Services en liste -->
    <section class="mb-8 border-b border-accent/25 pb-6">
      <h2 class="text-xl font-semibold mb-3">{text.servicesTitle}</h2>
      {text.services.map(s => (
        <div class="mb-4 border-l-2 border-accent pl-3">
          <h3 class="font-semibold">{s.title} — <span class="text-accent">{s.price}</span></h3>
          <p class="mb-1">{s.description}</p>
          <ul class="list-disc pl-5 text-sm">
            {s.features.map(f => <li>{f}</li>)}
          </ul>
          <p class="text-accent text-sm italic mt-1">{s.ideal}</p>
        </div>
      ))}
    </section>

    <!-- Workflow -->
    <section class="mb-8 border-b border-accent/25 pb-6">
      <h2 class="text-xl font-semibold mb-3">Workflow</h2>
      <ol class="list-decimal pl-5">
        {text.processSteps.map(s => (
          <li class="mb-2"><strong>{s.title}</strong> : {s.desc}</li>
        ))}
      </ol>
    </section>

    <!-- Détails en details/summary — padding au lieu de margin dans le contenu -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">{text.detailsTitle}</h2>

      <details class="mb-3 border border-accent/25 rounded p-2">
        <summary class="font-semibold text-light cursor-pointer py-1 flex items-center gap-2"><Icon name="monitor" size={16} class="shrink-0" />{text.vitrineDetails.title}</summary>
        <div class="pt-3 pl-2">
          {text.vitrineDetails.options.map(o => (
            <div class="pb-4 border-l-2 border-accent pl-3">
              <h3 class="font-semibold">{o.name} — <span class="text-accent">{o.price}</span></h3>
              <p class="text-sm text-text-muted pb-1">{o.maintenance}</p>
              <p class="pb-1">{o.desc}</p>
              <ul class="list-disc pl-5 text-sm pb-1">
                {o.features.map(f => <li>{f}</li>)}
              </ul>
              <p class="text-accent text-sm italic">{o.ideal}</p>
            </div>
          ))}
        </div>
      </details>

      <details class="mb-3 border border-accent/25 rounded p-2">
        <summary class="font-semibold text-light cursor-pointer py-1 flex items-center gap-2"><Icon name="cart" size={16} class="shrink-0" />{text.ecommerceDetails.title}</summary>
        <div class="pt-3 pl-2">
          {text.ecommerceDetails.options.map(o => (
            <div class="pb-4 border-l-2 border-accent pl-3">
              <h3 class="font-semibold">{o.name} — <span class="text-accent">{o.price}</span></h3>
              <p class="text-sm text-text-muted pb-1">{o.maintenance}</p>
              <p class="pb-1">{o.desc}</p>
              <ul class="list-disc pl-5 text-sm pb-1">
                {o.features.map(f => <li>{f}</li>)}
              </ul>
              <p class="text-accent text-sm italic">{o.ideal}</p>
            </div>
          ))}
        </div>
      </details>

      <details class="mb-3 border border-accent/25 rounded p-2">
        <summary class="font-semibold text-light cursor-pointer py-1 flex items-center gap-2"><Icon name="gear" size={16} class="shrink-0" />{text.customDetails.title}</summary>
        <div class="pt-3 pl-2 pb-2">
          <p class="text-accent font-semibold pb-2">{text.customDetails.rate}</p>
          <p class="pb-2">{text.customDetails.desc}</p>
          <ul class="list-disc pl-5 text-sm">
            {text.customDetails.examples.map(e => <li>{e}</li>)}
          </ul>
        </div>
      </details>
    </section>

    <!-- Inclus -->
    <section class="mb-8 border-t border-accent/25 pt-6">
      <h3 class="font-semibold mb-2">{text.includesTitle}</h3>
      <ul class="list-disc pl-5 mb-4 text-sm">
        {text.includes.map(i => <li>{i}</li>)}
      </ul>
    </section>

    <!-- Formulaire devis -->
    <section class="mb-8 border-t border-accent/25 pt-6">
      <h2 class="text-xl font-semibold mb-4">{text.ctaTitle}</h2>
      <FormWeb3Eco
        fromName="Portfolio Services - Eco Mode"
        redirectUrl={`${Astro.url.origin}/${lang}/contact/thanks/`}
        submitLabel={text.submitButton}
        afterFormText={text.contactDirect.text}
      >
        <div>
          <label for="name" class="block mb-1 font-medium">{text.nameLabel} *</label>
          <input type="text" id="name" name="name" class="w-full p-2 form-field" required />
        </div>
        <div>
          <label for="email" class="block mb-1 font-medium">{text.emailLabel} *</label>
          <input type="email" id="email" name="email" class="w-full p-2 form-field" required />
        </div>
        <div>
          <label for="company" class="block mb-1 font-medium">{text.companyLabel}</label>
          <input type="text" id="company" name="company" class="w-full p-2 form-field" />
        </div>
        <div>
          <label for="project_type" class="block mb-1 font-medium">{text.projectTypeLabel} *</label>
          <select id="project_type" name="project_type" class="w-full p-2 form-field" required>
            {Object.entries(text.projectTypes).map(([val, label]) => <option value={val}>{label}</option>)}
          </select>
        </div>
        <div>
          <label for="message" class="block mb-1 font-medium">{text.messageLabel} *</label>
          <textarea id="message" name="message" rows="4" class="w-full p-2 form-field" placeholder={text.messagePlaceholder} required></textarea>
        </div>
      </FormWeb3Eco>
      <p class="text-accent mt-4 text-sm flex gap-4">
        <span class="select-all">+33 7 81 33 97 68</span>
        <span class="select-all">josshanel@gmail.com</span>
      </p>
    </section>
  </div>
</LayoutEco>
