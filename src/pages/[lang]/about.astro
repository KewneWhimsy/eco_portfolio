---
// src/pages/[lang]/about.astro — v2 avec i18n
import Layout from '../../layouts/layout.astro';
import { Picture } from 'astro:assets';
import monImage from '../../assets/j.jpg';
import CtaDispo from '../../components/cta_dispo.astro';
import SkillsWithDescriptions from '../../components/skills_with_descriptions.astro';
import { getLangPaths, t } from '../../i18n';
import { about } from '../../i18n/about';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(about, lang);
---

<Layout title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-8" id="about-page">
    <!-- Introduction -->
    <section class="mb-12">
      <h1 class="text-3xl font-bold mb-4 border-b border-accent pb-2">{text.aboutTitle}</h1>
      <div class="flex flex-col md:flex-row justify-between gap-8">
        <div class="md:w-2/3 max-w-3xl">
          <p class="text-lg lg:text-xl mb-6">{text.aboutText}</p>
          <h2 class="text-xl font-semibold mb-3 text-accent">{text.visionTitle}</h2>
          <p class="text-balance max-w-2xl lg:text-lg" set:html={text.visionText} />
        </div>
        <div class="md:w-1/3">
          <div class="bg-secondary p-4 max-w-3/5 md:max-w-full mx-auto md:mx-0 border border-accent/20 shadow-[0_4px_24px_color-mix(in_srgb,var(--color-accent)_10%,transparent)] rounded-lg">
            <Picture
              src={monImage}
              widths={[400, 600]}
              formats={['avif', 'webp', 'jpg']}
              alt={`Josselin HANEL - ${text.aboutTitle}`}
              class="w-full h-auto object-cover rounded"
              data-astro-transition-persist="profile-image"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Compétences avec toggle -->
    <section class="mb-12">
      <div class="flex flex-col md:flex-row justify-between items-center mb-6">
        <h2 class="text-2xl font-bold border-b border-accent pb-2">{text.skillsTitle}</h2>
        <div class="inline-flex items-center border border-accent/20 px-4 py-2 rounded-lg mt-4 md:mt-0 gap-3">
          <input type="checkbox" id="tech-toggle" class="hidden" onclick="document.body.classList.toggle('tech-mode');" />
          <label for="tech-toggle" class="flex items-center gap-3 cursor-pointer">
            <div class="relative w-14 h-7 bg-primary border border-accent rounded-full">
              <div class="toggle-dot absolute top-1 left-1 bg-accent w-5 h-5 rounded-full transition-transform duration-300"></div>
            </div>
            <span class="tech-mode transition-colors text-text-muted text-sm tracking-wide">{text.techToggle}</span>
          </label>
        </div>
      </div>
      <SkillsWithDescriptions lang={lang} skills={text.skillCategories} />
    </section>

    <!-- Expérience -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 border-b border-accent pb-2">{text.expTitle}</h2>
      <div class="space-y-6">
        {text.experiences.map(exp => (
          <div class="border-l-2 border-accent pl-4 py-2">
            <div class="flex flex-wrap justify-between mb-2">
              <h3 class="text-xl font-semibold">{exp.position}</h3>
              <span class="text-text-muted">{exp.period}</span>
            </div>
            <p class="text-accent mb-2">{exp.company}</p>
            <p>{exp.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Formation -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 border-b border-accent pb-2">{text.eduTitle}</h2>
      <div class="space-y-6">
        {text.education.map(edu => (
          <div class="border-l-2 border-accent pl-4 py-2">
            <div class="flex flex-wrap justify-between mb-2">
              <h3 class="text-xl font-semibold">{edu.degree}</h3>
              <span class="text-text-muted">{edu.year}</span>
            </div>
            <p class="text-accent mb-2">{edu.school}</p>
            <p>{edu.description}</p>
          </div>
        ))}
      </div>
    </section>

    <CtaDispo transition-persist="cta-dispo" />
  </div>
</Layout>
