---
// src/pages/[lang]/contact/eco.astro — original restauré, layout éco + i18n
import LayoutEco from "../../../layouts/layout-eco.astro";
import EcoModeInfo from "../../../components/eco_mode_info.astro";
import { Picture } from 'astro:assets';
import monImage from "../../../assets/j.jpg";
import { getLangPaths, t } from '../../../i18n';
import { contact } from '../../../i18n/contact';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as "fr" | "en" | "de";
const text = t(contact, lang);

// Contact info
const contactInfo = {
  email: "josshanel@gmail.com",
  phone: "+33 7 81 33 97 68"
};

// L'URL complète vers la page de remerciement (incluant le domaine)
const redirectUrl = `${Astro.url.origin}/${lang}/contact/thanks/`;
---

<LayoutEco
  title={text.title}
  description={text.description}
  lang={lang}
>
  <div class="container mx-auto px-4 py-6 max-w-3xl">
    <!-- Utilisation du composant EcoModeInfo -->
    <EcoModeInfo lang={lang} />

    <h1 class="text-2xl font-bold mb-4 border-b border-accent pb-2">
      {text.pageTitle}
    </h1>

    <div class="flex flex-col gap-6">
      <p class="mb-4">
        {text.introText}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Informations de contact simplifiées -->
        <section>
          <div class="border border-accent/25 rounded-lg p-5 mb-6">
            <div class="flex justify-between">
              <div>
                <!-- Email -->
                <p class="mb-4 flex items-center text-link select-all">
                  {contactInfo.email}
                </p>
            
                <!-- Téléphone -->
                <p class="mb-4 flex items-center text-link select-all">
                  {contactInfo.phone}
                </p>
              </div>
              <Picture
                src={monImage}
                width={256}
                formats={["avif", "webp", "jpg"]}
                alt="Josselin HANEL"
                class="w-32 h-32 flex-shrink-0 border-2 border-accent rounded block md:hidden"
                data-astro-transition-persist="profile-image"
                loading="eager"
              />
            </div>
            <!-- Localisation -->
            <div class="mb-2">
              <h3 class="font-medium mb-1">{text.locationTitle}</h3>
              <p set:html={text.locationText} />
            </div>

          </div>
          
          <Picture
          src={monImage}
          width={384}
          formats={["avif", "webp", "jpg"]}
          alt="Josselin HANEL"
          class="w-88 h-88 flex-shrink-0 border-2 border-accent rounded hidden md:block mx-auto"
          data-astro-transition-persist="profile-image"
          loading="eager"
          />
        </section>

        <!-- Formulaire de contact simplifié avec action directe vers Web3Forms -->
        <section>
          <form
            method="POST"
            action="https://api.web3forms.com/submit"
            class="space-y-4"
          >
            <!-- Clé API Web3Forms -->
            <input
              type="hidden"
              name="access_key"
              value="2dcc3f1b-036f-48a7-987a-cdada0d05ae5"
            />
            <input type="hidden" name="from_name" value="Portfolio Contact - Eco Mode" />
            
            <!-- URL de redirection après soumission -->
            <input type="hidden" name="redirect" value={redirectUrl} />

            <!-- Champ nom -->
            <div>
              <label for="name" class="block mb-1 font-medium"
                >{text.formName} *</label
              >
              <input
                type="text"
                id="name"
                name="name"
                class="w-full p-2 form-field"
                required
              />
            </div>

            <!-- Champ email -->
            <div>
              <label for="email" class="block mb-1 font-medium"
                >{text.formEmail} *</label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full p-2 form-field"
                required
              />
            </div>
            
            <!-- Téléphone -->
            <div>
              <label for="phone" class="block mb-1 font-medium">{text.formPhone}</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                class="w-full p-2 form-field"
              />
            </div>

            <!-- Sujet -->
            <div>
              <label for="subject" class="block mb-1 font-medium">{text.formSubject} *</label>
              <select 
                id="subject" 
                name="subject" 
                class="w-full p-2 form-field"
                required
              >
                <option value={text.subjectOptions.quote}>{text.subjectOptions.quote}</option>
                <option value={text.subjectOptions.info}>{text.subjectOptions.info}</option>
                <option value={text.subjectOptions.partnership}>{text.subjectOptions.partnership}</option>
                <option value={text.subjectOptions.other}>{text.subjectOptions.other}</option>
              </select>
            </div>

            <!-- Champ message -->
            <div class="my-10">
              <label for="message" class="block mb-1 font-medium"
                >{text.formMessage} *</label
              >
              <textarea
                id="message"
                name="message"
                class="w-full p-2 h-48 form-field"
                placeholder={text.formMessagePlaceholder}
                required></textarea>
            </div>

            <!-- Champ honeypot pour éviter le spam -->
            <div class="hidden">
              <input type="text" name="botcheck" />
            </div>

            <!-- Bouton d'envoi -->
            <div class="flex justify-between items-center">
              <p class="text-xs text-text-muted">{text.afterFormText}</p>
              <button
                type="submit"
                class="cta-button"
              >
                {text.formSubmit}
              </button>
            </div>
          </form>
        </section>
      </div>
    </div>
  </div>
</LayoutEco>
