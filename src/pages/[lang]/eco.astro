---
// src/pages/[lang]/eco.astro — Homepage éco, mêmes traductions, template léger
import LayoutEco from '../../layouts/layout-eco.astro';
import { Picture } from 'astro:assets';
import monImage from '../../assets/j.jpg';
import CtaDispo from '../../components/cta_dispo.astro';
import EcoModeInfo from '../../components/eco_mode_info.astro';
import { getCollection } from 'astro:content';
import { loadHeroImage } from '../../utils/imageLoader';
import { getLangPaths, t } from '../../i18n';
import { home } from '../../i18n/home';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(home, lang);

const allProjects = await getCollection('projects');
const recentProjects = allProjects.sort((a, b) => b.data.order - a.data.order).slice(0, 2);

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<LayoutEco title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-8">
    <EcoModeInfo lang={lang} />

    <!-- Hero simplifié -->
    <section class="py-6 border-b border-accent/25 mb-6">
      <div class="flex flex-wrap gap-6 items-center">
        <div class="flex-1">
          <h1 class="text-2xl font-bold mb-3">
            {text.heroTypePart1} <span class="text-light">{text.heroTypePart2}</span>
          </h1>
          <p class="mb-4 text-balance max-w-5xl">{text.heroText}</p>
          <div class="flex flex-wrap gap-3">
            <a href={`/${lang}/contact/eco/`} class="cta-button">{text.contactButton}</a>
            <a href={`/${lang}/projects/eco/`} class="btn-secondary">{text.projectsButton}</a>
          </div>
        </div>
        <Picture
          src={monImage}
          width={128}
          formats={['avif', 'webp', 'jpg']}
          alt="Josselin HANEL"
          class="w-32 h-32 shrink-0 border-2 border-accent rounded"
          loading="eager"
        />
      </div>
    </section>

    <!-- Valeurs en liste -->
    <section class="py-6 border-b border-accent/25 mb-6">
      <ul class="list-disc pl-5">
        {text.values.map(v => (
          <li class="mb-2"><strong>{v.title}</strong> : {v.description}</li>
        ))}
      </ul>
    </section>

    <!-- Services en liste -->
    <section class="py-6 border-b border-accent/25 mb-6">
      <h2 class="text-xl font-bold mb-3">{text.servicesTitle}</h2>
      <ul class="list-disc pl-5">
        {text.services.map(s => (
          <li class="mb-2"><strong>{s.title}</strong> : {s.description}</li>
        ))}
      </ul>
    </section>

    <!-- Blog récent -->
    {recentPosts.length > 0 && (
      <section class="py-6 border-b border-accent/25 mb-6">
        <h2 class="text-xl font-bold mb-3">{text.blogTitle}</h2>
        <div class="space-y-3">
          {recentPosts.map(post => (
            <div class="border-b border-accent/10 pb-3">
              <a href={`/${lang}/blog/${post.data.slug}/eco/`} class="text-link font-medium">
                {post.data.title[lang]}
              </a>
              <p class="text-sm text-text-muted">{post.data.description[lang]}</p>
            </div>
          ))}
        </div>
        <a href={`/${lang}/blog/eco/`} class="text-link text-sm mt-3 inline-block">
          {text.viewAllBlogButton} →
        </a>
      </section>
    )}

    <!-- Projets récents -->
    <section class="py-6 mb-6">
      <h2 class="text-xl font-bold mb-4">{text.projectsTitle}</h2>
      <div class="space-y-4">
        {recentProjects.map(async (project) => {
          const heroImage = await loadHeroImage(project.data.slug);
          return (
            <div class="flex items-start gap-3 pb-4 border-b border-accent/10">
              <Picture
                src={heroImage}
                width={128}
                formats={['avif', 'webp', 'png']}
                alt=""
                class="w-16 h-16 object-cover rounded shrink-0 opacity-90"
                loading="lazy"
              />
              <div>
                <h3 class="font-medium mb-1">{project.data.title[lang]}</h3>
                <p class="mb-1 text-sm">{project.data.description[lang]}</p>
                <p class="text-xs text-text-muted mb-1">{project.data.tech.join(', ')}</p>
                <a href={`/${lang}/${project.data.slug}/eco/`} class="text-link text-sm">{text.projectButton}</a>
              </div>
            </div>
          );
        })}
      </div>
      <a href={`/${lang}/projects/eco/`} class="text-link text-sm mt-3 inline-block">
        {text.viewAllProjectsButton} →
      </a>
    </section>

    <CtaDispo withBackground={false} />
  </div>
</LayoutEco>
