---
// src/pages/[lang]/network/eco.astro — layout fidèle à l'original (grille 2 cols)
import LayoutEco from '../../../layouts/layout-eco.astro';
import EcoModeInfo from '../../../components/eco_mode_info.astro';
import { Picture } from 'astro:assets';
import jadeImage from '../../../assets/network/jade.jpeg';
import ninoImage from '../../../assets/network/nino.jpg';
import francoisImage from '../../../assets/network/francois.jpg';
import violetteImage from '../../../assets/network/violette.jpg';
import { getLangPaths, t } from '../../../i18n';
import { network } from '../../../i18n/network';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(network, lang);

const collaborators = [
  {
    name: 'Nino Leskargo', image: ninoImage,
    title: lang === 'fr' ? 'Tatoueur & Dessinateur' : lang === 'en' ? 'Tattoo Artist & Illustrator' : 'Tätowierer & Illustrator',
    description: lang === 'fr'
      ? 'Nino mélange le réalisme précis et le style graffiti/cartoon dans ses tatouages. Il est aussi très doué pour le dessin 2D.'
      : lang === 'en'
      ? 'Nino blends precise realism with graffiti/cartoon aesthetics in his tattoos, showing versatile talent as a 2D illustrator.'
      : 'Nino kombiniert präzisen Realismus mit Graffiti- und Cartoon-Ästhetik in seinen Tattoos.',
    skills: ['Tattoo Art', '2D Illustration', 'Graffiti', 'Urban Art'],
    portfolio: 'https://www.instagram.com/leskargo__/',
  },
  {
    name: 'Jade Ounaphom', image: jadeImage,
    title: lang === 'fr' ? 'Designer & Créatrice vidéo' : lang === 'en' ? 'UI/UX Designer & Audiovisual Creator' : 'UI/UX Designer & Audiovisuelle Gestalterin',
    description: lang === 'fr'
      ? 'Jade apporte un regard unique aux projets web grâce à ses talents en design et en création vidéo.'
      : lang === 'en'
      ? 'Jade brings a unique vision to digital projects thanks to her dual expertise in design and audiovisual creation.'
      : 'Jade bringt mit ihrer Doppelkompetenz in Design und audiovisueller Gestaltung eine einzigartige Vision ein.',
    skills: ['UI/UX Design', 'Figma', 'Adobe CC', 'Motion Design'],
    portfolio: 'https://jadephom.myportfolio.com/',
  },
  {
    name: 'François Bourdin', image: francoisImage,
    title: lang === 'fr' ? 'Créateur de personnages' : 'Character Designer & Concept Artist',
    description: lang === 'fr'
      ? "François est spécialiste de la création de personnages et du design artistique. Son style moderne est très apprécié dans le monde de l'animation."
      : lang === 'en'
      ? 'François brings sharp artistic expertise in character and concept design, with a modern style in the animation industry.'
      : 'François bringt scharfe künstlerische Expertise im Character- und Concept Design.',
    skills: ['Character Design', 'Concept Art', 'Animation', 'Illustration'],
    portfolio: 'https://www.artstation.com/franoisbourdin',
  },
  {
    name: 'Violette Dubois', image: violetteImage,
    title: lang === 'fr' ? 'Cheffe de Projet & Spécialiste No-Code' : lang === 'en' ? 'Web Project Manager & No-Code Expert' : 'Web-Projektleiterin & Automatisierungsexpertin',
    description: lang === 'fr'
      ? "Violette a d'abord travaillé dans les castings TV avant de se tourner vers le web. Elle gère maintenant des projets web et utilise des outils comme Zapier ou Notion pour automatiser les tâches."
      : lang === 'en'
      ? 'Violette worked for years in TV casting before moving into web projects. She now drives projects using tools like Zapier and Notion.'
      : 'Violette war mehrere Jahre im TV-Casting tätig, bevor sie ins Web wechselte. Sie steuert Projekte mit Tools wie Zapier und Notion.',
    skills: ['Gestion de projet', 'No-code (Zapier, Notion)', 'Communication', 'Organisation', 'Initiation au code (42)'],
    portfolio: 'https://www.linkedin.com/in/violette-dubois-02169b139',
  },
];
---

<LayoutEco title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-6">
    <EcoModeInfo lang={lang} />

    <h1 class="text-2xl font-bold mb-6 border-b border-accent pb-2">
      {text.networkTitle}
    </h1>
    
    <p class="text-lg mb-10 max-w-4xl">
      {text.networkIntro}
    </p>

    <!-- Grille 2 colonnes comme l'original -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {collaborators.map(person => (
        <div class="bg-opacity-30 rounded-lg border border-accent/25 p-4">
          <!-- En-tête : photo ronde + nom + titre vert -->
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-full overflow-hidden shrink-0">
              <Picture
                src={person.image}
                width={64}
                height={64}
                alt={person.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="font-bold">{person.name}</h3>
              <p class="text-accent text-sm">{person.title}</p>
            </div>
          </div>
          
          <!-- Description -->
          <p class="mb-3">{person.description}</p>
          
          <!-- Skills en texte simple -->
          <p class="text-text-muted text-sm mb-3">
            {person.skills.join('')}
          </p>
          
          <!-- Lien texte vert -->
          {person.portfolio && (
            <a href={person.portfolio} target="_blank" rel="noopener noreferrer" class="text-link text-sm">
              {text.viewWork}
            </a>
          )}
        </div>
      ))}
    </div>

    <section class="border border-accent/20 rounded-2xl rounded-tr-none rounded-bl-none py-8 text-center">
      <h2 class="text-2xl font-bold mb-4 px-2 sm:px-1">{text.contactCTA}</h2>
      <a href={`/${lang}/contact/eco/`} class="cta-button">{text.contactButton}</a>
    </section>
  </div>
</LayoutEco>
