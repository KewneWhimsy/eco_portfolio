---
// src/pages/[lang]/about/eco.astro — menus déroulants avec descriptions simples
import LayoutEco from '../../../layouts/layout-eco.astro';
import EcoModeInfo from '../../../components/eco_mode_info.astro';
import CtaDispo from '../../../components/cta_dispo.astro';
import Icon from '../../../components/Icon.astro';
import { getLangPaths, t } from '../../../i18n';
import { about } from '../../../i18n/about';
import { getSimpleDescription } from '../../../i18n/skills';

export function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as 'fr' | 'en' | 'de';
const text = t(about, lang);
---

<LayoutEco title={text.title} description={text.description} lang={lang}>
  <div class="container mx-auto px-4 py-6">
    <EcoModeInfo lang={lang} />

    <section class="mb-8 border-b border-accent/25 pb-6">
      <h1 class="text-2xl font-bold mb-4 border-b border-accent pb-2">{text.aboutTitle}</h1>
      <p class="mb-4 max-w-4xl">{text.aboutText}</p>
      <h2 class="text-xl font-semibold mb-2">{text.visionTitle}</h2>
      <p class="mb-4 max-w-4xl" set:html={text.visionText} />
    </section>

    <!-- Compétences en menus déroulants avec descriptions simples -->
    <section class="mb-4 max-w-3xl">
      <h2 class="text-xl font-semibold mb-3">{text.skillsTitle}</h2>
      {text.skillCategories.map(cat => (
        <details class="mb-3 border border-accent/25 rounded p-2">
          <summary class="flex items-center gap-3 text-lg font-semibold text-light cursor-pointer py-1">
            {cat.icon && <Icon name={cat.icon as any} size={20} class="text-light shrink-0" />}
            {cat.category}
          </summary>
          <div class="pt-3 pl-2">
            {cat.items.map(item => {
              const desc = getSimpleDescription(item, lang);
              return (
                <div class="pb-2">
                  <div class="font-medium text-light">{item}</div>
                  {desc && <p class="pb-1 max-w-lg text-balance">{desc}</p>}
                </div>
              );
            })}
          </div>
        </details>
      ))}
    </section>

    <!-- Expérience -->
    <section class="my-10 border-t border-b border-accent/25 pb-6 pt-10">
      <h2 class="text-xl font-semibold mb-3">{text.expTitle}</h2>
      <div class="space-y-4">
        {text.experiences.map(exp => (
          <div class="border-l-2 border-accent pl-3 py-1">
            <div class="flex flex-wrap justify-between mb-1">
              <h3 class="font-semibold">{exp.position}</h3>
              <span class="text-text-muted text-sm">{exp.period}</span>
            </div>
            <p class="text-light text-sm mb-1">{exp.company}</p>
            <p>{exp.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Formation -->
    <section class="mb-8 border-b border-accent/25 pb-6">
      <h2 class="text-xl font-semibold mb-3">{text.eduTitle}</h2>
      <div class="space-y-4">
        {text.education.map(edu => (
          <div class="border-l-2 border-accent pl-3 py-1">
            <div class="flex flex-wrap justify-between mb-1">
              <h3 class="font-semibold">{edu.degree}</h3>
              <span class="text-text-muted text-sm">{edu.year}</span>
            </div>
            <p class="text-light text-sm mb-1">{edu.school}</p>
            <p>{edu.description}</p>
          </div>
        ))}
      </div>
    </section>

    <CtaDispo withBackground={false} />
  </div>
</LayoutEco>
