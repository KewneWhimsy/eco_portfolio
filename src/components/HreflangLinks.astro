---
const { pathname } = Astro.url;

const langs = ['fr', 'en', 'de'] as const;
type Lang = typeof langs[number];

const langCodes: Record<Lang, string> = {
  fr: 'fr-FR',
  en: 'en-US',
  de: 'de-DE'
};

function getPathWithoutLang(path: string): string {
  const cleanPath = path.replace(/^\/[a-z]{2}/, '');
  return cleanPath.replace(/\/{2,}/g, '/').replace(/\/?$/, '/');
}

const pathWithoutLang = getPathWithoutLang(pathname);
const siteBase = (import.meta.env.SITE || 'https://jkw.ovh').replace(/\/$/, '');
---

{langs.map((lang) => (
  <link rel="alternate" hreflang={langCodes[lang]} href={`${siteBase}/${lang}${pathWithoutLang}`} />
))}

<link rel="alternate" hreflang="x-default" href={`${siteBase}/fr${pathWithoutLang}`} />
