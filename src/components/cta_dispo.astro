---
// src/components/cta_dispo.astro — v2 avec i18n
import { t } from '../i18n';
import { cta } from '../i18n/common';
import Icon from './Icon.astro';

export interface Props {
  withBackground?: boolean;
}

const { withBackground = true } = Astro.props;
const lang = (Astro.params.lang as 'fr' | 'en' | 'de') || 'fr';
const text = t(cta, lang);
---

<section class={`py-8 ${withBackground ? 'border border-accent/20 rounded-[1rem] rounded-tr-none rounded-bl-none shadow-[0_4px_24px_color-mix(in_srgb,var(--color-accent)_8%,transparent)]' : ''} text-center mt-8 overflow-hidden relative`}>
  <h2 class="text-2xl font-bold mb-4 px-1">{text.ctaTitle}</h2>
  <p class="mb-6 max-w-lg mx-auto px-1">{text.ctaText}</p>

  <div class="flex flex-col justify-center items-center gap-4">
    <a href={`/${lang}/contact/`} class="cta-button">
      {text.contactButton}
    </a>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <p class="text-light flex items-center gap-2"><Icon name="phone" size={16} class="shrink-0" /><span class="select-all">{text.phone}</span></p>
      <p class="text-light flex items-center gap-2"><Icon name="mail" size={16} class="shrink-0" /><span class="select-all">{text.email}</span></p>
    </div>
  </div>
</section>
