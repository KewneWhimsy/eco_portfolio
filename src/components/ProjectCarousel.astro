---
// src/components/ProjectCarousel.astro — Carrousel d'images pour les pages projet
import { Picture } from 'astro:assets';
import Icon from './Icon.astro';

interface Props {
  images: any[];
  alt: string;
  contain?: boolean;
  transitionName?: string;
  prevLabel?: string;
  nextLabel?: string;
  closeLabel?: string;
}

const {
  images,
  alt,
  contain = false,
  transitionName,
  prevLabel = 'Image précédente',
  nextLabel = 'Image suivante',
  closeLabel = 'Fermer',
} = Astro.props;

const imageClass = `${contain ? 'max-h-64 w-auto' : 'w-full max-h-[32rem] object-contain'} rounded-lg select-none cursor-zoom-in group-[.is-fullscreen]:w-[92vw] group-[.is-fullscreen]:h-[90vh] group-[.is-fullscreen]:max-w-[92vw] group-[.is-fullscreen]:max-h-[90vh] group-[.is-fullscreen]:rounded-none group-[.is-fullscreen]:object-contain group-[.is-fullscreen]:cursor-zoom-out`;
---

{images.length > 0 && (
  <div
    class="project-carousel group relative mb-10 [&.is-fullscreen]:fixed [&.is-fullscreen]:inset-0 [&.is-fullscreen]:z-[100] [&.is-fullscreen]:m-0 [&.is-fullscreen]:flex [&.is-fullscreen]:items-center [&.is-fullscreen]:bg-black/92"
    data-carousel
  >
    <div
      class="carousel-viewport overflow-hidden rounded-lg bg-secondary bg-opacity-30 group-[.is-fullscreen]:h-full group-[.is-fullscreen]:w-full group-[.is-fullscreen]:rounded-none group-[.is-fullscreen]:bg-transparent"
      data-viewport
    >
      <div
        class="carousel-track flex transition-transform duration-300 ease-in-out touch-pan-y group-[.is-fullscreen]:h-full"
        data-track
      >
        {images.map((image, index) => (
          <div class="carousel-slide w-full shrink-0 flex items-center justify-center p-4">
            <Picture
              src={image}
              widths={[400, 800, 1200, 1600]}
              sizes="(max-width: 1024px) 100vw, 1024px"
              formats={["avif", "webp", "jpg"]}
              alt={`${alt} ${index + 1}`}
              class={imageClass}
              loading={index === 0 ? 'eager' : 'lazy'}
              transition:name={index === 0 ? transitionName : undefined}
              data-zoomable
            />
          </div>
        ))}
      </div>
    </div>

    <button
      type="button"
      class="hidden absolute top-4 right-4 z-10 h-9 w-9 items-center justify-center rounded-full border border-white/30 bg-white/10 text-white transition duration-200 hover:bg-white/20 group-[.is-fullscreen]:flex"
      data-close
      aria-label={closeLabel}
    >
      <Icon name="close" size={20} />
    </button>

    {images.length > 1 && (
      <>
        <button
          type="button"
          class="absolute top-1/2 left-3 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full border border-(--color-border) bg-(--color-primary) text-(--color-accent) opacity-[0.85] transition duration-200 hover:opacity-100 hover:bg-(--color-accent-light) disabled:opacity-30 disabled:pointer-events-none group-[.is-fullscreen]:border-white/30 group-[.is-fullscreen]:bg-white/10 group-[.is-fullscreen]:text-white group-[.is-fullscreen]:hover:bg-white/20"
          data-prev
          aria-label={prevLabel}
        >
          <Icon name="chevron-left" size={22} />
        </button>
        <button
          type="button"
          class="absolute top-1/2 right-3 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full border border-(--color-border) bg-(--color-primary) text-(--color-accent) opacity-[0.85] transition duration-200 hover:opacity-100 hover:bg-(--color-accent-light) disabled:opacity-30 disabled:pointer-events-none group-[.is-fullscreen]:border-white/30 group-[.is-fullscreen]:bg-white/10 group-[.is-fullscreen]:text-white group-[.is-fullscreen]:hover:bg-white/20"
          data-next
          aria-label={nextLabel}
        >
          <Icon name="chevron-right" size={22} />
        </button>
      </>
    )}
  </div>
)}

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
      if (carousel.dataset.carouselReady) return;
      carousel.dataset.carouselReady = 'true';

      const viewport = carousel.querySelector<HTMLElement>('[data-viewport]');
      const track = carousel.querySelector<HTMLElement>('[data-track]');
      const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
      const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-prev]');
      const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-next]');
      const closeBtn = carousel.querySelector<HTMLElement>('[data-close]');
      if (!viewport || !track || slides.length === 0) return;

      let currentIndex = 0;

      const updateTrack = () => {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        if (prevBtn) prevBtn.disabled = currentIndex === 0;
        if (nextBtn) nextBtn.disabled = currentIndex === slides.length - 1;
      };

      const goTo = (index: number) => {
        currentIndex = Math.max(0, Math.min(slides.length - 1, index));
        updateTrack();
      };

      const setFullscreen = (open: boolean) => {
        carousel.classList.toggle('is-fullscreen', open);
        document.documentElement.classList.toggle('overflow-hidden', open);
      };

      slides.forEach((slide) => {
        slide.querySelector('img')?.addEventListener('click', () => {
          if (!carousel.classList.contains('is-fullscreen')) setFullscreen(true);
        });
        slide.addEventListener('click', (event) => {
          if (carousel.classList.contains('is-fullscreen') && event.target === slide) {
            setFullscreen(false);
          }
        });
      });

      closeBtn?.addEventListener('click', () => setFullscreen(false));

      document.addEventListener('keydown', (event) => {
        if (!carousel.classList.contains('is-fullscreen')) return;
        if (event.key === 'Escape') setFullscreen(false);
        else if (event.key === 'ArrowLeft') goTo(currentIndex - 1);
        else if (event.key === 'ArrowRight') goTo(currentIndex + 1);
      });

      prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
      nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));

      // Glissement tactile, comme sur les galeries du site briec2000
      let startX = 0;
      viewport.addEventListener('touchstart', (event) => {
        startX = event.touches[0].clientX;
      }, { passive: true });
      viewport.addEventListener('touchend', (event) => {
        const deltaX = event.changedTouches[0].clientX - startX;
        if (Math.abs(deltaX) > 50) {
          deltaX > 0 ? goTo(currentIndex - 1) : goTo(currentIndex + 1);
        }
      }, { passive: true });

      updateTrack();
    });
  }

  document.addEventListener('astro:page-load', initCarousels);
</script>
