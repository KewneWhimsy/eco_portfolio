---
// src/components/ProjectCarousel.astro — Carrousel d'images pour les pages projet
import { Picture } from 'astro:assets';
import Icon from './Icon.astro';

interface Props {
  images: any[];
  alt: string;
  contain?: boolean;
  transitionName?: string;
  prevLabel?: string;
  nextLabel?: string;
  closeLabel?: string;
}

const {
  images,
  alt,
  contain = false,
  transitionName,
  prevLabel = 'Image précédente',
  nextLabel = 'Image suivante',
  closeLabel = 'Fermer',
} = Astro.props;

const imageClass = `${contain ? 'max-h-64 w-auto' : 'w-full max-h-[32rem] object-contain'} rounded-lg cursor-zoom-in group-[:popover-open]:w-[92vw] group-[:popover-open]:h-[90vh] group-[:popover-open]:max-w-none group-[:popover-open]:max-h-none group-[:popover-open]:object-contain group-[:popover-open]:cursor-zoom-out`;
---

{images.length > 0 && (
  <div class="project-carousel-wrapper">
    <div class="project-carousel mb-10" data-carousel>
      <div class="carousel-stage relative" data-stage>
        <div
          class="carousel-viewport overflow-hidden rounded-lg bg-secondary bg-opacity-30"
          data-viewport
        >
          <div
            class="carousel-track flex transition-transform duration-300 ease-in-out touch-pan-y"
            data-track
          >
            {images.map((image, index) => (
              <div class="carousel-slide w-full shrink-0 flex items-center justify-center p-4">
                <Picture
                  src={image}
                  widths={[800, 1600]}
                  sizes="(max-width: 1024px) 100vw, 1024px"
                  formats={["avif", "webp"]}
                  alt={`${alt} ${index + 1}`}
                  class={imageClass}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  transition:name={index === 0 ? transitionName : undefined}
                />
              </div>
            ))}
          </div>
        </div>

        {images.length > 1 && (
          <>
            <button
              type="button"
              class="absolute top-1/2 left-3 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full border border-(--color-border) bg-primary text-accent opacity-[0.85] transition duration-200 hover:opacity-100 hover:bg-(--color-accent-light) disabled:opacity-30 disabled:pointer-events-none"
              data-prev
              aria-label={prevLabel}
            >
              <Icon name="chevron-left" size={22} />
            </button>
            <button
              type="button"
              class="absolute top-1/2 right-3 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full border border-(--color-border) bg-primary text-accent opacity-[0.85] transition duration-200 hover:opacity-100 hover:bg-(--color-accent-light) disabled:opacity-30 disabled:pointer-events-none"
              data-next
              aria-label={nextLabel}
            >
              <Icon name="chevron-right" size={22} />
            </button>
          </>
        )}
      </div>
    </div>

    <!-- Lightbox plein écran : popover natif, fermeture gérée par le navigateur (Échap, clic extérieur) -->
    <div popover tabindex="-1" data-lightbox class="lightbox group">
      <button
        type="button"
        class="absolute top-4 right-4 z-10 flex h-9 w-9 items-center justify-center rounded-full border border-white/30 bg-white/10 text-white transition duration-200 hover:bg-white/20"
        data-close
        aria-label={closeLabel}
      >
        <Icon name="close" size={20} />
      </button>
    </div>
  </div>
)}

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    margin: 0;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    padding: 0;
    border: 0;
    background: rgb(0 0 0 / 0.92);
    opacity: 0;
    transition: display 0.2s allow-discrete, opacity 0.2s ease;
    transition-behavior: allow-discrete;
  }

  .lightbox:popover-open {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;

    @starting-style {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox {
      transition: display 0.2s allow-discrete, opacity 0.2s ease;
    }
  }

  /* Le stage est déplacé dans la lightbox à l'ouverture : il en occupe alors tout l'espace */
  .lightbox:popover-open .carousel-stage,
  .lightbox:popover-open .carousel-viewport,
  .lightbox:popover-open .carousel-track,
  .lightbox:popover-open .carousel-slide {
    width: 100%;
    height: 100%;
  }

  .lightbox:popover-open .carousel-viewport {
    background: transparent;
    border-radius: 0;
  }
</style>

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
      if (carousel.dataset.carouselReady) return;
      carousel.dataset.carouselReady = 'true';

      const wrapper = carousel.parentElement;
      const lightbox = wrapper?.querySelector<HTMLElement>('[data-lightbox]');
      const stage = carousel.querySelector<HTMLElement>('[data-stage]');
      const viewport = carousel.querySelector<HTMLElement>('[data-viewport]');
      const track = carousel.querySelector<HTMLElement>('[data-track]');
      const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
      const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-prev]');
      const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-next]');
      const closeBtn = lightbox?.querySelector<HTMLElement>('[data-close]');
      if (!lightbox || !stage || !viewport || !track || slides.length === 0) return;

      const stageHome = carousel;
      let currentIndex = 0;

      const updateTrack = () => {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        if (prevBtn) prevBtn.disabled = currentIndex === 0;
        if (nextBtn) nextBtn.disabled = currentIndex === slides.length - 1;
      };

      const goTo = (index: number) => {
        currentIndex = Math.max(0, Math.min(slides.length - 1, index));
        updateTrack();
      };

      const openLightbox = () => {
        lightbox.append(stage);
        (lightbox as any).showPopover();
        setTimeout(() => lightbox.focus(), 50);
      };

      // Le popover natif gère Échap et le clic en dehors ; on se contente de
      // remettre le carrousel à sa place quand il se ferme, peu importe la cause.
      lightbox.addEventListener('toggle', (event: any) => {
        if (event.newState === 'closed') stageHome.append(stage);
      });

      stage.addEventListener('click', (event) => {
        const target = event.target as HTMLElement;
        if (target.closest('button')) return;

        const isOpen = lightbox.matches(':popover-open');
        if (target.tagName === 'IMG') {
          isOpen ? (lightbox as any).hidePopover() : openLightbox();
        } else if (isOpen) {
          (lightbox as any).hidePopover();
        }
      });

      closeBtn?.addEventListener('click', () => (lightbox as any).hidePopover());

      lightbox.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'ArrowLeft') { event.preventDefault(); goTo(currentIndex - 1); }
        else if (event.key === 'ArrowRight') { event.preventDefault(); goTo(currentIndex + 1); }
      });

      prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
      nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));

      // Glissement tactile, comme sur les galeries du site briec2000
      let startX = 0;
      viewport.addEventListener('touchstart', (event) => {
        startX = event.touches[0].clientX;
      }, { passive: true });
      viewport.addEventListener('touchend', (event) => {
        const deltaX = event.changedTouches[0].clientX - startX;
        if (Math.abs(deltaX) > 50) {
          deltaX > 0 ? goTo(currentIndex - 1) : goTo(currentIndex + 1);
        }
      }, { passive: true });

      updateTrack();
    });
  }

  document.addEventListener('astro:page-load', initCarousels);
</script>
