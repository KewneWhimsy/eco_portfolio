---
// src/components/BlogArticleContent.astro
// Composant unifié pour un article de blog (standard + éco)
import EcoModeInfo from './eco_mode_info.astro';
import CtaDispo from './cta_dispo.astro';
import { t } from '../i18n';
import { blog } from '../i18n/blog';
import { formatDate } from '../utils/blog';
import type { Lang } from '../i18n';

export interface Props {
  post: any;
  htmlContent: string;
  related: any[];
  lang: Lang;
  isEco?: boolean;
}

const { post, htmlContent, related, lang, isEco = false } = Astro.props;
const text = t(blog, lang);
const ecoSuffix = isEco ? '/eco' : '';

const articleClasses = "[&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-accent [&>h2]:mb-3 [&>h2]:mt-8 [&>h2]:border-b [&>h2]:border-accent [&>h2]:pb-2 [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:text-accent [&>h3]:mb-2 [&>h3]:mt-6 [&>p]:mb-4 [&>p]:leading-relaxed [&>strong]:font-semibold [&>strong]:text-light [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-4 [&>ul]:space-y-2 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-4 [&>ol]:space-y-2 [&>li]:leading-relaxed [&>hr]:border-accent/20 [&>hr]:my-8 [&>blockquote]:border-l-4 [&>blockquote]:border-accent [&>blockquote]:pl-4 [&>blockquote]:italic [&>blockquote]:my-4";
---

<div class="container mx-auto px-4 py-6 max-w-3xl">
  {isEco && <EcoModeInfo lang={lang} />}

  <!-- Navigation retour -->
  <div class="mb-6">
    <a href={`/${lang}/blog${ecoSuffix}/`} class="text-text-muted hover:text-accent transition-colors">
      {text.backToBlog}
    </a>
  </div>

  <!-- En-tête -->
  <header class="mb-8">
    <h1 class={`${isEco ? 'text-2xl' : 'text-3xl'} font-bold mb-3 border-b border-accent pb-2`}>
      {post.data.title[lang]}
    </h1>

    <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted mb-4">
      <time datetime={post.data.date.toISOString()}>
        {text.publishedOn} {formatDate(post.data.date, lang)}
      </time>
    </div>

    {/* Tags : pills cliquables en standard, texte simple en éco */}
    {isEco ? (
      <p class="text-xs text-text-muted">{post.data.tags.join(', ')}</p>
    ) : (
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag: string) => (
          <a
            href={`/${lang}/blog/?tag=${encodeURIComponent(tag)}`}
            class="px-2 py-0.5 border border-accent text-accent rounded-full text-xs hover:bg-accent hover:text-white transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )}
  </header>

  <!-- Contenu -->
  <article class={`mb-12 ${articleClasses}`} set:html={htmlContent} />

  <!-- Articles similaires -->
  {related.length > 0 && (
    <section class="mb-8 border-t border-accent/20 pt-6">
      <h2 class={`${isEco ? 'text-lg' : 'text-xl'} font-bold mb-4`}>{text.relatedPosts}</h2>

      {isEco ? (
        related.map(r => (
          <div class="mb-3">
            <a href={`/${lang}/blog/${r.data.slug}/eco/`} class="text-link font-medium">
              {r.data.title[lang]}
            </a>
            <p class="text-sm text-text-muted">{r.data.description[lang]}</p>
          </div>
        ))
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(r => (
            <a
              href={`/${lang}/blog/${r.data.slug}/`}
              class="project-card p-4"
            >
              <h3 class="font-semibold mb-1">{r.data.title[lang]}</h3>
              <p class="text-sm text-text-muted">{r.data.description[lang]}</p>
            </a>
          ))}
        </div>
      )}
    </section>
  )}

  <CtaDispo withBackground={!isEco} />
</div>

<style>
  article :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    transition: color var(--transition-standard);
  }
  article :global(a:hover) {
    color: var(--color-light);
  }
</style>
