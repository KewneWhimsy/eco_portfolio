---
// src/components/BlogListContent.astro
// Composant unifié pour la liste du blog (standard + éco)
import EcoModeInfo from './eco_mode_info.astro';
import { t } from '../i18n';
import { blog } from '../i18n/blog';
import { formatDate } from '../utils/blog';
import type { Lang } from '../i18n';

export interface Props {
  posts: any[];
  lang: Lang;
  isEco?: boolean;
}

const { posts, lang, isEco = false } = Astro.props;
const text = t(blog, lang);
const ecoSuffix = isEco ? '/eco' : '';

// Tags uniques (utilisés seulement en mode standard)
const allTags = [...new Set(posts.flatMap(post => post.data.tags))].sort();
---

<div class="container mx-auto px-4 py-6">
  {isEco && <EcoModeInfo lang={lang} />}

  <h1 class={`${isEco ? 'text-2xl' : 'text-3xl'} font-bold mb-4 border-b border-accent pb-2`}>
    {text.pageTitle}
  </h1>
  <p class={`${isEco ? 'mb-6' : 'text-lg mb-8'}`}>{text.pageIntro}</p>

  {/* Filtres par tag — mode standard uniquement */}
  {!isEco && (
    <div class="flex flex-wrap gap-2 mb-8" id="tag-filters">
      <button class="tag-btn active px-3 py-1 rounded-full text-sm border border-accent" data-tag="all">
        {text.allTags}
      </button>
      {allTags.map(tag => (
        <button class="tag-btn px-3 py-1 rounded-full text-sm border border-accent/30" data-tag={tag}>
          {tag}
        </button>
      ))}
    </div>
  )}

  {/* Liste des articles */}
  <div class={isEco ? 'space-y-4' : 'space-y-6'} id="blog-list">
    {posts.map(post => (
      <a
        href={`/${lang}/blog/${post.data.slug}${ecoSuffix}/`}
        class={isEco
          ? 'block border-b border-accent/30 pb-4'
          : 'blog-card article-link block py-5 border-b border-accent/10'}
        data-tags={post.data.tags.join(',')}
      >
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 sm:gap-4 mb-1 sm:mb-2">
          {isEco ? (
            <span class="font-semibold text-accent">{post.data.title[lang]}</span>
          ) : (
            <h2 class="text-xl font-bold text-accent">{post.data.title[lang]}</h2>
          )}
          <div class="flex sm:flex-col sm:items-end gap-2 sm:gap-0.5 shrink-0 whitespace-nowrap text-sm text-text-muted">
            <span>{formatDate(post.data.date, lang)}</span>
          </div>
        </div>

        <p class={isEco ? 'text-sm mb-1 max-w-6xl' : 'mb-3 max-w-6xl'}>{post.data.description[lang]}</p>

        {isEco ? (
          <p class="text-xs text-text-muted">{post.data.tags.join(', ')}</p>
        ) : (
          <div class="flex flex-wrap items-center gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="px-2 py-0.5 border border-accent text-accent rounded-full text-xs">{tag}</span>
            ))}
            <span class="ml-auto text-accent text-sm">{text.readMore} →</span>
          </div>
        )}
      </a>
    ))}
  </div>

  <p id="no-results" class={`text-text-muted text-center py-8${posts.length > 0 ? ' hidden' : ''}`}>
    {text.noResults}
  </p>
</div>

<style>
  .article-link h2 {
    transition: color var(--transition-standard);
  }
  .article-link:hover h2 {
    color: var(--color-light);
  }
</style>
{!isEco && (
  <script>
    document.addEventListener('astro:page-load', () => {
      const buttons = document.querySelectorAll('.tag-btn');
      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('no-results');

      function activateTag(tag: string) {
        buttons.forEach(b => {
          b.classList.remove('active', 'border-accent', 'text-accent');
          b.classList.add('border-accent/30');
        });
        const target = tag === 'all'
          ? document.querySelector('.tag-btn[data-tag="all"]')
          : document.querySelector(`.tag-btn[data-tag="${tag}"]`);
        if (target) {
          target.classList.add('active', 'border-accent', 'text-accent');
          target.classList.remove('border-accent/30');
        }
        let visibleCount = 0;
        cards.forEach(card => {
          const cardTags = card.getAttribute('data-tags')?.split(',') || [];
          const show = tag === 'all' || cardTags.includes(tag);
          (card as HTMLElement).style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });
        if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);
      }

      const paramTag = new URLSearchParams(window.location.search).get('tag');
      if (paramTag) activateTag(paramTag);

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tag = btn.getAttribute('data-tag') || 'all';
          activateTag(tag);
        });
      });
    });
  </script>
)}
