---
// src/components/eco_mode_info.astro — v2 avec i18n
import { t } from '../i18n';
import { ecoMode } from '../i18n/common';

export interface Props {
  lang: 'fr' | 'en' | 'de';
}
const { lang } = Astro.props;
const text = t(ecoMode, lang);
---

<div class="mb-6 border border-accent/25 rounded-lg px-3 py-2 flex items-baseline gap-2">
  <span class="font-bold shrink-0">{text.infoTitle} —</span>
  <span class="text-sm text-text-muted text-pretty">{text.infoDesc}</span>
</div>
