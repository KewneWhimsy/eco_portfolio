---
// src/components/eco_mode_info.astro — v2 avec i18n
import { t } from '../i18n';
import { ecoMode } from '../i18n/common';

export interface Props {
  lang: 'fr' | 'en' | 'de';
}
const { lang } = Astro.props;
const text = t(ecoMode, lang);
---

<details class="mb-6 border border-secondary rounded-lg">
  <summary class="font-bold text-xl p-3 cursor-pointer"><span class="ml-0.5">{text.infoTitle}</span></summary>
  <div class="px-3 pb-3 pt-2 border-t border-secondary">
    <p class="pb-3">{text.infoText}</p>
    <ul class="list-disc pl-5 pb-3">
      {text.infoFeatures.map((f: string) => <li>{f}</li>)}
    </ul>
    <p class="text-sm text-balance max-w-xl">{text.infoExplanation}</p>
  </div>
</details>
