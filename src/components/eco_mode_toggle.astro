---
// src/components/eco_mode_toggle.astro — URL-based toggle avec i18n
import { getLangFromPath, t } from '../i18n';
import { ecoMode } from '../i18n/common';

import Icon from './Icon.astro';

const { pathname } = Astro.url;
const currentLang = getLangFromPath(pathname);
const isEcoMode = pathname.includes('/eco');
const text = t(ecoMode, currentLang);

// Calculer l'URL pour basculer le mode
let toggleUrl: string;
if (isEcoMode) {
  // Éco → Standard : on enlève "/eco" de l'URL
  if (pathname === `/${currentLang}/eco` || pathname === `/${currentLang}/eco/`) {
    toggleUrl = `/${currentLang}/`;
  } else {
    toggleUrl = pathname.replace('/eco', '');
  }
} else {
  // Standard → Éco : on ajoute "/eco" à l'URL
  if (pathname === `/${currentLang}` || pathname === `/${currentLang}/` || pathname === `/${currentLang}/index/`) {
    toggleUrl = `/${currentLang}/eco/`;
  } else {
    toggleUrl = pathname.endsWith('/') ? `${pathname}eco/` : `${pathname}/eco/`;
  }
}

const label = isEcoMode ? text.toggleLabelStandard : text.toggleLabel;
---

<div class="relative flex items-center">
  <a href={toggleUrl} class="btn-eco flex items-center gap-2 px-3 py-1 rounded-full border border-accent text-sm">
    <span>{label}</span>
    <Icon name="leaf" size={20} />
  </a>
</div>
