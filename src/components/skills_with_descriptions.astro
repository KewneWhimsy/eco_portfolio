---
// src/components/skills_with_descriptions.astro — utilise i18n/skills.ts
import { getDescription } from '../i18n/skills';
import type { Lang } from '../i18n';
import Icon from './Icon.astro';

export interface Props {
  lang: Lang;
  skills: Array<{
    category: string;
    icon?: string;
    items: readonly string[];
  }>;
}

const { lang, skills } = Astro.props;
---

<div class="skills-grid">
  {skills.map(skill => (
    <div class="skill-card">
      <div class="skill-card-bar" aria-hidden="true"></div>
      <div class="skill-card-header">
        <h3 class="skill-card-title">{skill.category}</h3>
        {skill.icon && (
          <span class="skill-card-icon">
            <Icon name={skill.icon as any} size={26} />
          </span>
        )}
      </div>
      <div class="skill-items">
        {skill.items.map(item => {
          const desc = getDescription(item, lang);
          return (
            <div class="skill-item">
              <span class="skill-item-dot" aria-hidden="true"></span>
              <div class="skill-item-content">
                <span class="skill-item-name">{item}</span>
                <p class="technical-desc skill-item-desc">{desc.technical}</p>
                <p class="simple-desc skill-item-desc">{desc.simple}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  ))}
</div>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .skill-card {
    position: relative;
    background: color-mix(in srgb, var(--color-secondary) 25%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
    border-top-right-radius: 0;
    border-bottom-left-radius: 0;
    overflow: hidden;
  }

  /* Barre accent en haut */
  .skill-card-bar {
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-light), transparent);
    opacity: 0.7;
  }

  .skill-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.1rem 1.25rem 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
    margin-bottom: 0.25rem;
  }

  .skill-card-title {
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .skill-card-icon {
    color: var(--color-light);
    margin-top: -0.4rem;
    margin-right: -0.4rem;
  }

  .skill-items {
    padding: 0.5rem 1.25rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .skill-item {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    padding: 0.5rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-secondary) 40%, transparent);
  }

  .skill-item:last-child {
    border-bottom: none;
  }

  .skill-item-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    /* Centre le dot sur le cap-height de la première ligne (font-size 1rem, line-height ~1.5) */
    margin-top: calc((1rem * 1.5 - 4px) / 2);
  }

  .skill-item-content {
    flex: 1;
    min-width: 0;
  }

  .skill-item-name {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text, inherit);
    margin-bottom: 0.2rem;
  }

  .skill-item-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted, #888);
    line-height: 1.5;
    text-wrap: pretty;
    margin: 0;
  }
</style>
